#!/usr/bin/env python3

import argparse
import configparser
import copy
import logging
import os
import pathlib
import re
import shutil
import sys
from io import StringIO

import yaml
import subprocess

# --- Configuration ---
TARGET_BASE_DIR = pathlib.Path.home() / "containers"
SYSTEMD_CONFIG_DIR = pathlib.Path.home() / ".config" / "containers" / "systemd"
SECRET_PLACEHOLDER_PATTERN = re.compile(r"\{\{\s*(\w+)\s*\}\}")
DEFAULT_SECRETS_FILE = "secrets.yml"
DEFAULT_INVENTORY_FILE = None  # No default - must be explicitly specified or use --all

# --- Set up logging ---
logging.basicConfig(
    level=logging.INFO, format="%(asctime)s [%(levelname)-4s] %(message)s"
)
logger = logging.getLogger(__name__)

# --- Helper Functions ---


def substitute_secrets(content: str, secrets: dict) -> str:
    """Substitutes {{ secret_name }} placeholders in content."""

    def replace_match(match):
        secret_name = match.group(1)
        if secret_name in secrets:
            return str(secrets[secret_name])
        else:
            # Keep the placeholder if the secret is not found, log a warning
            logger.warning(f"Secret '{secret_name}' not found in secrets file.")
            return match.group(0)  # Return the original placeholder

    return SECRET_PLACEHOLDER_PATTERN.sub(replace_match, content)


def is_likely_text_file(file_path: pathlib.Path) -> bool:
    """Tries to detect if a file is likely text-based (UTF-8)."""
    try:
        # Try reading a small chunk to detect encoding errors early
        with open(file_path, "r", encoding="utf-8") as f:
            f.read(1024)  # Read first 1KB
        return True
    except UnicodeDecodeError:
        return False
    except Exception as e:
        # Handle other potential read errors if necessary
        logger.warning(f"Could not read file {file_path} to check if text: {e}")
        return False  # Assume binary if unsure


def merge_ini_content(base_content: str, overlay_content: str) -> str:
    """
    Merge INI-style files (like .container quadlet files).
    Overlay values override base values. Keys not in overlay are preserved.
    Handles duplicate keys (like multiple Label= lines) by accumulating values.
    """
    # Parse both files manually to handle duplicate keys
    def parse_ini_with_duplicates(content: str) -> dict:
        """Parse INI content, accumulating duplicate keys into lists."""
        sections = {}
        current_section = None
        for line in content.splitlines():
            line = line.strip()
            if not line or line.startswith("#") or line.startswith(";"):
                continue
            if line.startswith("[") and line.endswith("]"):
                current_section = line[1:-1]
                if current_section not in sections:
                    sections[current_section] = {}
            elif "=" in line and current_section:
                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip()
                if key in sections[current_section]:
                    # Convert to list if not already
                    existing = sections[current_section][key]
                    if isinstance(existing, list):
                        existing.append(value)
                    else:
                        sections[current_section][key] = [existing, value]
                else:
                    sections[current_section][key] = value
        return sections

    def write_ini_with_duplicates(sections: dict) -> str:
        """Write INI content, expanding lists into duplicate keys."""
        lines = []
        for section, keys in sections.items():
            lines.append(f"[{section}]")
            for key, value in keys.items():
                if isinstance(value, list):
                    for v in value:
                        lines.append(f"{key}={v}")
                else:
                    lines.append(f"{key}={value}")
            lines.append("")  # Blank line between sections
        return "\n".join(lines)

    base_sections = parse_ini_with_duplicates(base_content)
    overlay_sections = parse_ini_with_duplicates(overlay_content)

    # Merge overlay into base
    for section, keys in overlay_sections.items():
        if section not in base_sections:
            base_sections[section] = {}
        for key, value in keys.items():
            # For duplicate-key fields, overlay extends (not replaces) base
            if key in base_sections[section] and isinstance(value, list):
                existing = base_sections[section][key]
                if isinstance(existing, list):
                    existing.extend(value)
                else:
                    base_sections[section][key] = [existing] + value
            else:
                base_sections[section][key] = value

    return write_ini_with_duplicates(base_sections)


def deep_merge_dict(base: dict, overlay: dict) -> dict:
    """Deep merge two dicts. Overlay values win on conflicts."""
    result = copy.deepcopy(base)
    for key, value in overlay.items():
        if (
            key in result
            and isinstance(result[key], dict)
            and isinstance(value, dict)
        ):
            result[key] = deep_merge_dict(result[key], value)
        else:
            result[key] = copy.deepcopy(value)
    return result


def merge_yaml_content(base_content: str, overlay_content: str) -> str:
    """Merge YAML files with deep merge. Overlay values win on conflicts."""
    base_data = yaml.safe_load(base_content) or {}
    overlay_data = yaml.safe_load(overlay_content) or {}
    merged = deep_merge_dict(base_data, overlay_data)
    return yaml.dump(merged, default_flow_style=False, sort_keys=False)


def get_source_dir(container_dir: pathlib.Path) -> pathlib.Path:
    """Return base/ subdirectory if it exists, otherwise container_dir itself."""
    base_dir = container_dir / "base"
    return base_dir if base_dir.is_dir() else container_dir


def get_overlay_dir(container_dir: pathlib.Path, hostname: str) -> pathlib.Path | None:
    """Return overlay directory for hostname if it exists."""
    overlay_dir = container_dir / "overlays" / hostname
    return overlay_dir if overlay_dir.is_dir() else None


def merge_file_content(
    base_content: str, overlay_content: str, file_name: str
) -> str:
    """Merge file content based on file extension."""
    if file_name.endswith(".container"):
        return merge_ini_content(base_content, overlay_content)
    elif file_name.endswith((".yml", ".yaml")):
        return merge_yaml_content(base_content, overlay_content)
    else:
        # For other files, overlay completely replaces base
        return overlay_content


def load_inventory(inventory_path: pathlib.Path, hostname: str) -> set:
    """Loads inventory file and returns set of containers for the given hostname."""
    if not inventory_path.exists():
        return None

    try:
        with open(inventory_path, "r") as f:
            inventory = yaml.safe_load(f)

        if not isinstance(inventory, dict):
            logger.error(
                f"Inventory file {inventory_path} must contain a YAML dictionary."
            )
            sys.exit(1)

        # Check if hostname is in inventory
        if hostname in inventory:
            containers = inventory[hostname]
            if isinstance(containers, list):
                return set(containers)
            else:
                logger.error(
                    f"Containers for hostname '{hostname}' must be a list in inventory file."
                )
                sys.exit(1)
        else:
            logger.warning(
                f"Hostname '{hostname}' not found in inventory. No containers will be installed."
            )
            logger.info(f"Available hosts in inventory: {', '.join(inventory.keys())}")
            return set()

    except yaml.YAMLError as e:
        logger.error(f"Error parsing inventory file {inventory_path}: {e}")
        sys.exit(1)
    except IOError as e:
        logger.error(f"Could not read inventory file {inventory_path}: {e}")
        sys.exit(1)


def create_podman_secrets(container_name: str, podman_secrets: list, secrets: dict):
    """Creates podman secrets for specified secret names."""
    for secret_name in podman_secrets:
        if secret_name not in secrets:
            logger.error(
                f"Required secret '{secret_name}' for container '{container_name}' not found in secrets file."
            )
            sys.exit(1)

        # Check if secret already exists in podman
        check_cmd = ["podman", "secret", "inspect", secret_name]
        try:
            process = subprocess.run(check_cmd, capture_output=True, text=True)
            secret_exists = process.returncode == 0
        except Exception as e:
            logger.error(f"Failed to check if secret '{secret_name}' exists: {e}")
            sys.exit(1)

        # If secret exists, remove it first (to update)
        if secret_exists:
            logger.debug(f"Removing existing secret '{secret_name}'")
            try:
                subprocess.run(["podman", "secret", "rm", secret_name], check=True)
            except subprocess.CalledProcessError as e:
                logger.error(f"Failed to remove existing secret '{secret_name}': {e}")
                sys.exit(1)

        # Create the secret
        logger.info(f"Creating podman secret: {secret_name}")
        try:
            # Use echo to pass the secret value to podman
            create_cmd = ["podman", "secret", "create", secret_name, "-"]
            process = subprocess.Popen(create_cmd, stdin=subprocess.PIPE, text=True)
            process.communicate(input=str(secrets[secret_name]))
            if process.returncode != 0:
                logger.error(f"Failed to create secret '{secret_name}'")
                sys.exit(1)
        except Exception as e:
            logger.error(f"Error creating secret '{secret_name}': {e}")
            sys.exit(1)


# --- Main Logic ---


def main():
    parser = argparse.ArgumentParser(
        description="Installs container configurations, substituting secrets.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "--secrets",
        type=pathlib.Path,
        default=DEFAULT_SECRETS_FILE,
        help="Path to the secrets.yml file.",
    )
    parser.add_argument(
        "--inventory",
        type=pathlib.Path,
        default=DEFAULT_INVENTORY_FILE,
        help="Path to the inventory.yml file.",
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="Install all containers, ignoring inventory file.",
    )
    parser.add_argument(
        "--restart", "-r", action="store_true", help="Restart containers"
    )
    parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose (debug) logging"
    )
    args = parser.parse_args()

    # Set logging level based on verbosity
    if args.verbose:
        logger.setLevel(logging.DEBUG)

    script_dir = pathlib.Path(__file__).parent.resolve()
    secrets_path = args.secrets
    inventory_path = args.inventory

    # --- Get hostname and load inventory ---
    current_hostname = os.uname().nodename
    logger.info(f"Current hostname: {current_hostname}")

    allowed_containers = None
    if not args.all:
        if inventory_path is None:
            logger.error(
                "No inventory file specified. Either provide --inventory <path> or use --all to install all containers."
            )
            sys.exit(1)
        allowed_containers = load_inventory(inventory_path, current_hostname)
        if allowed_containers is None:
            logger.error(f"Inventory file not found at {inventory_path}.")
            sys.exit(1)
        elif len(allowed_containers) == 0:
            logger.info("No containers to install for this host.")
        else:
            logger.info(
                f"Containers to install: {', '.join(sorted(allowed_containers))}"
            )
    else:
        logger.info("Installing all containers (--all flag specified).")

    # --- Load Secrets ---
    secrets = {}
    if secrets_path.exists():
        logger.info(f"Loading secrets from: {secrets_path}")
        try:
            with open(secrets_path, "r") as f:
                secrets = yaml.safe_load(f)
                if not isinstance(secrets, dict):
                    logger.error(
                        f"Secrets file {secrets_path} must contain a YAML dictionary (key-value pairs)."
                    )
                    sys.exit(1)
        except yaml.YAMLError as e:
            logger.error(f"Error parsing secrets file {secrets_path}: {e}")
            sys.exit(1)
        except IOError as e:
            logger.error(f"Could not read secrets file {secrets_path}: {e}")
            sys.exit(1)
    else:
        logger.info(
            f"Secrets file not found at {secrets_path}. Proceeding without secret substitution."
        )

    # --- Ensure Target Base Directory Exists ---
    logger.info(f"Ensuring target base directory exists: {TARGET_BASE_DIR}")
    TARGET_BASE_DIR.mkdir(parents=True, exist_ok=True)

    # --- Process Container Subdirectories ---
    logger.info(f"Searching for container directories in: {script_dir}")
    found_containers = False
    containers = []
    for item in script_dir.iterdir():
        if item.is_dir() and not item.name.startswith(".") and item.name != "__pycache__":
            # Basic check for container dir
            container_name = item.name

            # Check if this container should be installed based on inventory
            if (
                allowed_containers is not None
                and container_name not in allowed_containers
            ):
                logger.debug(
                    f"Skipping container '{container_name}' (not in inventory for this host)"
                )
                continue

            containers.append(container_name)
            source_dir = item
            target_dir = TARGET_BASE_DIR / container_name
            found_containers = True

            logger.info(f"Processing container '{container_name}':")

            # --- Detect base/overlay structure ---
            base_dir = get_source_dir(source_dir)
            overlay_dir = get_overlay_dir(source_dir, current_hostname)
            uses_base_overlay = base_dir != source_dir

            if uses_base_overlay:
                logger.debug(f"  Using base/overlay structure")
                logger.debug(f"  Base: {base_dir}")
                if overlay_dir:
                    logger.debug(f"  Overlay: {overlay_dir}")
                else:
                    logger.debug(f"  No overlay for hostname '{current_hostname}'")
            else:
                logger.debug(f"  Using flat structure (no base/ directory)")
                logger.debug(f"  Source: {source_dir}")

            logger.debug(f"  Target: {target_dir}")

            # --- Read container's config.yml if it exists ---
            # Check in root first (shared config), then base
            config_file = source_dir / "config.yml"
            if not config_file.exists() and uses_base_overlay:
                config_file = base_dir / "config.yml"

            if config_file.exists():
                try:
                    with open(config_file, "r") as f:
                        config = yaml.safe_load(f)

                    # Process podman_secrets configuration
                    if (
                        config
                        and isinstance(config, dict)
                        and "podman_secrets" in config
                    ):
                        podman_secrets_list = config.get("podman_secrets", [])
                        if podman_secrets_list and isinstance(
                            podman_secrets_list, list
                        ):
                            if secrets:
                                create_podman_secrets(
                                    container_name, podman_secrets_list, secrets
                                )
                            else:
                                logger.error(
                                    f"Container '{container_name}' requires secrets but no secrets file was loaded."
                                )
                                sys.exit(1)
                except yaml.YAMLError as e:
                    logger.error(f"Error parsing config file {config_file}: {e}")
                    sys.exit(1)
                except IOError as e:
                    logger.error(f"Could not read config file {config_file}: {e}")
                    sys.exit(1)

            target_dir.mkdir(parents=True, exist_ok=True)

            # --- Walk Base/Source Directory and Copy/Substitute/Merge ---
            for root, dirs, files in os.walk(base_dir):
                source_root = pathlib.Path(root)
                relative_path = source_root.relative_to(base_dir)
                target_root = target_dir / relative_path

                # Skip base/ and overlays/ directories in output
                dirs[:] = [d for d in dirs if d not in ("base", "overlays")]

                # Create directories
                for dir_name in dirs:
                    target_subdir = target_root / dir_name
                    if not target_subdir.exists():
                        logger.info(
                            f"    Creating dir:  {target_subdir.relative_to(TARGET_BASE_DIR)}"
                        )
                        target_subdir.mkdir()

                # Process files
                for file_name in files:
                    # Skip config.yml (internal use only)
                    if file_name == "config.yml":
                        continue

                    base_file = source_root / file_name
                    target_file = target_root / file_name
                    relative_file_path = target_file.relative_to(TARGET_BASE_DIR)

                    # Check if overlay file exists
                    overlay_file = None
                    if overlay_dir:
                        overlay_file_path = overlay_dir / relative_path / file_name
                        if overlay_file_path.exists():
                            overlay_file = overlay_file_path

                    if not is_likely_text_file(base_file):
                        # Copy binary files
                        logger.info(f"    Copying:     {relative_file_path}")
                        shutil.copy2(base_file, target_file)
                    elif overlay_file:
                        # Merge base + overlay, then substitute secrets
                        logger.info(f"    Merging:     {relative_file_path}")
                        try:
                            with open(base_file, "r", encoding="utf-8") as bf:
                                base_content = bf.read()
                            with open(overlay_file, "r", encoding="utf-8") as of:
                                overlay_content = of.read()

                            merged_content = merge_file_content(
                                base_content, overlay_content, file_name
                            )
                            if secrets:
                                merged_content = substitute_secrets(
                                    merged_content, secrets
                                )

                            with open(target_file, "w", encoding="utf-8") as tf:
                                tf.write(merged_content)
                            shutil.copymode(base_file, target_file)
                        except Exception as e:
                            logger.error(
                                f"Failed merging file {base_file} with {overlay_file}: {e}"
                            )
                            sys.exit(1)
                    else:
                        # No overlay - just substitute secrets
                        logger.info(f"    Substituting: {relative_file_path}")
                        try:
                            with open(base_file, "r", encoding="utf-8") as sf:
                                content = sf.read()

                            if secrets:
                                content = substitute_secrets(content, secrets)

                            with open(target_file, "w", encoding="utf-8") as tf:
                                tf.write(content)
                            shutil.copymode(base_file, target_file)
                        except Exception as e:
                            logger.error(f"Failed processing file {base_file}: {e}")
                            sys.exit(1)

                    # Create symlinks for container files to systemd directory
                    if file_name.endswith(".container"):
                        SYSTEMD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)

                        systemd_link = SYSTEMD_CONFIG_DIR / file_name
                        if systemd_link.exists() or systemd_link.is_symlink():
                            systemd_link.unlink()

                        logger.info(
                            f"    Creating symlink: {systemd_link} -> {target_file}"
                        )
                        try:
                            os.symlink(target_file, systemd_link)
                        except Exception as e:
                            logger.error(
                                f"Failed to create symlink for {file_name}: {e}"
                            )
                            sys.exit(1)

            # --- Process overlay-only files (files in overlay but not in base) ---
            if overlay_dir:
                for root, dirs, files in os.walk(overlay_dir):
                    overlay_root = pathlib.Path(root)
                    relative_path = overlay_root.relative_to(overlay_dir)
                    base_root = base_dir / relative_path
                    target_root = target_dir / relative_path

                    # Create directories that exist only in overlay
                    for dir_name in dirs:
                        target_subdir = target_root / dir_name
                        if not target_subdir.exists():
                            logger.info(
                                f"    Creating dir:  {target_subdir.relative_to(TARGET_BASE_DIR)}"
                            )
                            target_subdir.mkdir(parents=True, exist_ok=True)

                    for file_name in files:
                        if file_name == "config.yml":
                            continue

                        base_file = base_root / file_name
                        overlay_file = overlay_root / file_name
                        target_file = target_root / file_name

                        # Skip if already processed (exists in base)
                        if base_file.exists():
                            continue

                        relative_file_path = target_file.relative_to(TARGET_BASE_DIR)

                        if not is_likely_text_file(overlay_file):
                            logger.info(f"    Copying:     {relative_file_path} (overlay-only)")
                            shutil.copy2(overlay_file, target_file)
                        else:
                            logger.info(f"    Substituting: {relative_file_path} (overlay-only)")
                            try:
                                with open(overlay_file, "r", encoding="utf-8") as of:
                                    content = of.read()

                                if secrets:
                                    content = substitute_secrets(content, secrets)

                                with open(target_file, "w", encoding="utf-8") as tf:
                                    tf.write(content)
                                shutil.copymode(overlay_file, target_file)
                            except Exception as e:
                                logger.error(f"Failed processing overlay file {overlay_file}: {e}")
                                sys.exit(1)

                        if file_name.endswith(".container"):
                            SYSTEMD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
                            systemd_link = SYSTEMD_CONFIG_DIR / file_name
                            if systemd_link.exists() or systemd_link.is_symlink():
                                systemd_link.unlink()
                            logger.info(
                                f"    Creating symlink: {systemd_link} -> {target_file}"
                            )
                            try:
                                os.symlink(target_file, systemd_link)
                            except Exception as e:
                                logger.error(
                                    f"Failed to create symlink for {file_name}: {e}"
                                )
                                sys.exit(1)

    if not found_containers:
        logger.info("No container subdirectories found.")
    else:
        # Reload systemd to recognize new services
        logger.info("Reloading systemd to recognize new services...")
        try:
            subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
            logger.info("Systemd reloaded successfully.")
        except subprocess.CalledProcessError as e:
            logger.error(f"Failed to reload systemd: {e}")
            sys.exit(1)

        if args.restart:
            for container in containers:
                logger.info(f"Restart container: {container}")
                try:
                    subprocess.run(
                        ["systemctl", "--user", "restart", container], check=True
                    )
                    logger.info(f"Container {container} restarted successfully.")
                except subprocess.CalledProcessError as e:
                    logger.error(f"Failed to restart container {container}: {e}")
                    sys.exit(1)

    logger.info("Installation complete.")


if __name__ == "__main__":
    main()
